# 前端环境变量配置
# 复制此文件为 .env 并填入实际值

# Python 后端服务地址
VITE_PYTHON_BACKEND_URL=http://localhost:5000

# API 基础路径
VITE_API_BASE_PATH=/v1

# Mock 数据延迟（毫秒）
VITE_MOCK_DELAY_MS=500

# 时区配置
VITE_TIMEZONE=America/New_York

# IV 计算参数
VITE_IV_PUT_TARGET_FACTOR=0.93
VITE_IV_CALL_TARGET_FACTOR=1.07

# VRP 阈值
VITE_VRP_LOW_THRESHOLD=5
VITE_VRP_NORMAL_THRESHOLD=15
VITE_VRP_HIGH_THRESHOLD=30
VITE_VRP_WARNING_THRESHOLD=20

# 默认股票代码
VITE_DEFAULT_SYMBOL=QQQ

# 是否使用 Mock 数据（开发环境）
VITE_USE_MOCK=false
